{
  "name": "@itechgenie/itgps-agent",
  "version": "0.1.4",
  "description": "CLI agent that bridges ITG Playwright Studio data into local Playwright workflows",
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "itgps-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "playwright.config.cjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "vitest --run",
    "lint": "tsc --noEmit",
    "postinstall": "node -e \"console.log('\\n✓ @itechgenie/itgps-agent installed successfully!\\n\\nNext steps:\\n  1. Run: itgps-agent config\\n  2. Install Playwright browsers: npx playwright install\\n')\""
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:ITechGenie/itg-playwright-studio.git"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "itg-playwright-studio",
    "cli-agent",
    "workflow",
    "itgps-agent"
  ],
  "author": "ITechGenie",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ITechGenie/itg-playwright-studio/issues"
  },
  "homepage": "https://github.com/ITechGenie/itg-playwright-studio/blob/itgps-agent-init/itgps-agent/README.md",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@playwright/test": "^1.48.0",
    "dotenv": "^16.4.5",
    "monocart-reporter": "^2.11.2",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "fast-check": "^3.19.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
